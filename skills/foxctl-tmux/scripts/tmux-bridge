#!/usr/bin/env bash
# tmux-bridge - lightweight pane-to-pane interaction helper for live agent collaboration.
set -euo pipefail

VERSION="2.1.0"
TMUX_SOCKET=""

die() { echo "error: $*" >&2; exit 1; }

sender_id() {
  if [[ -n "${TMUX_BRIDGE_SENDER:-}" ]]; then
    echo "${TMUX_BRIDGE_SENDER//[^A-Za-z0-9._-]/_}"
    return
  fi
  if [[ -n "${TMUX_PANE:-}" ]]; then
    echo "${TMUX_PANE//[^A-Za-z0-9._-]/_}"
    return
  fi
  echo "pid_$$"
}

read_guard_path() {
  local pane_id="$1"
  local base="${TMPDIR:-/tmp}"
  local sender
  sender="$(sender_id)"
  printf "%s/tmux-bridge-read-%s-%s\n" "$base" "$sender" "${pane_id//[^A-Za-z0-9._-]/_}"
}

mark_read() {
  touch "$(read_guard_path "$1")"
}

require_read() {
  local guard
  guard="$(read_guard_path "$1")"
  if [[ ! -f "$guard" ]]; then
    die "must read the pane before interacting. Run: tmux-bridge read $1"
  fi
}

clear_read() {
  rm -f "$(read_guard_path "$1")"
}

detect_socket() {
  if [[ -n "${TMUX_BRIDGE_SOCKET:-}" ]]; then
    if [[ -S "$TMUX_BRIDGE_SOCKET" ]]; then
      echo "$TMUX_BRIDGE_SOCKET"
      return
    fi
    die "TMUX_BRIDGE_SOCKET=$TMUX_BRIDGE_SOCKET is not a valid socket"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    local socket="${TMUX%%,*}"
    if [[ -S "$socket" ]] && tmux -S "$socket" list-sessions &>/dev/null; then
      echo "$socket"
      return
    fi
  fi

  local pane="${TMUX_PANE:-}"
  if [[ -n "$pane" ]]; then
    local uid
    uid="$(id -u)"
    local sock_dirs=("/tmp/tmux-${uid}" "/private/tmp/tmux-${uid}")
    for sock_dir in "${sock_dirs[@]}"; do
      [[ -d "$sock_dir" ]] || continue
      for sock in "$sock_dir"/*; do
        [[ -S "$sock" ]] || continue
        if tmux -S "$sock" display-message -t "$pane" -p '#{pane_id}' &>/dev/null; then
          echo "$sock"
          return
        fi
      done
    done
    if tmux display-message -t "$pane" -p '#{pane_id}' &>/dev/null; then
      echo "__default__"
      return
    fi
  fi

  if tmux list-sessions &>/dev/null; then
    echo "__default__"
    return
  fi

  die "cannot find a reachable tmux server (TMUX=${TMUX:-<unset>}, TMUX_PANE=${TMUX_PANE:-<unset>})"
}

init_socket() {
  TMUX_SOCKET="$(detect_socket)"
}

tmx() {
  if [[ "$TMUX_SOCKET" == "__default__" || -z "$TMUX_SOCKET" ]]; then
    tmux "$@"
  else
    tmux -S "$TMUX_SOCKET" "$@"
  fi
}

usage() {
  cat <<'EOF'
tmux-bridge - cross-pane communication for AI agents

Usage: tmux-bridge <command> [args...]

Commands:
  list                      Show all panes (target, session, size, process, label, cwd)
  type <target> <text>      Type text without pressing Enter
  send <target> <text>      Send a bridge message and press Enter
  read <target> [lines]     Read last N lines from pane (default: 50)
  keys <target> <key>...    Send special keys (Enter, Escape, C-c, etc.)
  name <target> <label>     Label a pane (visible in tmux border)
  resolve <label>           Print pane target for a label
  id                        Print this pane's ID ($TMUX_PANE)
  doctor                    Diagnose tmux connectivity issues
  version                   Print version

Targets:
  Use a tmux pane id (%3), session target (work:1.0), or a label set with 'name'.

Environment:
  TMUX_BRIDGE_SOCKET   Override the tmux server socket path
  TMUX_BRIDGE_SENDER   Override the sender identity used for read guards
EOF
  exit 0
}

require_tmux() {
  command -v tmux >/dev/null 2>&1 || die "tmux is not installed or not in PATH"
}

resolve_label() {
  local label="$1"
  local result
  result="$(tmx list-panes -a -F '#{pane_id} #{@name}' 2>/dev/null | awk -v lbl="$label" '$2 == lbl { print $1; exit }')"
  [[ -n "$result" ]] || die "no pane found with label '$label'"
  echo "$result"
}

resolve_target() {
  local target="$1"
  if [[ "$target" =~ ^%[0-9]+$ ]]; then
    echo "$target"
    return
  fi
  if [[ "$target" == *:* ]] || [[ "$target" == *.* ]]; then
    echo "$target"
    return
  fi
  if [[ "$target" =~ ^[0-9]+$ ]]; then
    echo "$target"
    return
  fi
  resolve_label "$target"
}

validate_target() {
  local target="$1"
  tmx display-message -t "$target" -p '#{pane_id}' >/dev/null 2>&1 || die "invalid target: $target"
}

require_args() {
  local need="$1" have="$2" cmd="$3"
  if (( have < need )); then
    die "'$cmd' requires at least $need argument(s). Run 'tmux-bridge' for usage."
  fi
}

cmd_list() {
  printf "%-8s %-16s %-10s %-18s %-10s %s\n" "TARGET" "SESSION:PANE" "SIZE" "PROCESS" "LABEL" "CWD"
  tmx list-panes -a -F '#{pane_id}|#{session_name}|#{window_index}|#{pane_index}|#{pane_width}x#{pane_height}|#{pane_current_command}|#{@name}|#{pane_current_path}' \
    2>/dev/null | while IFS='|' read -r id sess widx pidx size proc label cwd; do
      cwd="${cwd/#$HOME/~}"
      printf "%-8s %-16s %-10s %-18s %-10s %s\n" \
        "$id" "${sess}:${widx}.${pidx}" "$size" "$proc" "${label:--}" "$cwd"
    done
}

cmd_type() {
  require_args 2 $# "type"
  local target
  target="$(resolve_target "$1")"
  validate_target "$target"
  require_read "$target"
  tmx send-keys -t "$target" -l -- "$2"
  clear_read "$target"
}

cmd_send() {
  require_args 2 $# "send"
  local target
  target="$(resolve_target "$1")"
  validate_target "$target"
  require_read "$target"

  local sender_pane="${TMUX_PANE:-}"
  local sender_label=""
  if [[ -n "$sender_pane" ]]; then
    sender_label="$(tmx display-message -t "$sender_pane" -p '#{@name}' 2>/dev/null || true)"
  fi
  local from="${sender_label:-${sender_pane:-$(sender_id)}}"
  local header="[tmux-bridge from=${from} pane=${sender_pane:-unknown} reply_to=${from}]"

  tmx send-keys -t "$target" -l -- "${header} $2"
  tmx send-keys -t "$target" Enter
  clear_read "$target"
}

cmd_read() {
  require_args 1 $# "read"
  local target
  target="$(resolve_target "$1")"
  validate_target "$target"
  local lines="${2:-50}"
  tmx capture-pane -t "$target" -p -J -S "-${lines}"
  mark_read "$target"
}

cmd_keys() {
  require_args 2 $# "keys"
  local target
  target="$(resolve_target "$1")"
  validate_target "$target"
  require_read "$target"
  shift
  for key in "$@"; do
    tmx send-keys -t "$target" "$key"
  done
  clear_read "$target"
}

cmd_name() {
  require_args 2 $# "name"
  local target
  target="$(resolve_target "$1")"
  validate_target "$target"
  tmx set-option -p -t "$target" @name "$2"
}

cmd_resolve() {
  require_args 1 $# "resolve"
  resolve_label "$1"
}

cmd_id() {
  [[ -n "${TMUX_PANE:-}" ]] || die "not running inside a tmux pane (\$TMUX_PANE is unset)"
  echo "$TMUX_PANE"
}

cmd_doctor() {
  require_tmux
  local ok=true

  echo "tmux-bridge doctor v${VERSION}"
  echo "---"
  echo "TMUX_PANE:          ${TMUX_PANE:-<unset>}"
  echo "TMUX:               ${TMUX:-<unset>}"
  echo "TMUX_BRIDGE_SOCKET: ${TMUX_BRIDGE_SOCKET:-<unset>}"
  echo "TMUX_BRIDGE_SENDER: ${TMUX_BRIDGE_SENDER:-<unset>}"

  if [[ -n "${TMUX:-}" ]]; then
    local env_socket="${TMUX%%,*}"
    if [[ -S "$env_socket" ]]; then
      if tmux -S "$env_socket" list-sessions &>/dev/null; then
        echo "\$TMUX socket:       $env_socket (reachable)"
      else
        echo "\$TMUX socket:       $env_socket (exists but not responding)"
        ok=false
      fi
    else
      echo "\$TMUX socket:       $env_socket (missing or stale)"
      ok=false
    fi
  fi

  echo "---"
  local detected
  detected="$(detect_socket 2>/dev/null || echo "__failed__")"
  if [[ "$detected" == "__failed__" ]]; then
    echo "Detected socket:    FAILED"
    ok=false
  elif [[ "$detected" == "__default__" ]]; then
    echo "Detected socket:    (default tmux server)"
    TMUX_SOCKET="__default__"
  else
    echo "Detected socket:    $detected"
    TMUX_SOCKET="$detected"
  fi

  echo "---"
  if [[ "$detected" != "__failed__" ]]; then
    local count
    count="$(tmx list-panes -a -F '#{pane_id}' 2>/dev/null | wc -l | tr -d ' ')"
    echo "Total panes:        $count"
    local labeled
    labeled="$(tmx list-panes -a -F '#{@name}' 2>/dev/null | grep -cv '^$' || echo 0)"
    echo "Labeled panes:      $labeled"
  fi

  echo "---"
  if $ok; then
    echo "Status: OK"
  else
    echo "Status: ISSUES DETECTED"
    return 1
  fi
}

[[ $# -eq 0 ]] && usage

case "$1" in
  id) shift; cmd_id "$@"; exit ;;
  doctor) shift; cmd_doctor "$@"; exit ;;
  version) echo "tmux-bridge $VERSION"; exit ;;
  help|-h|--help) usage ;;
esac

require_tmux
init_socket

case "$1" in
  list) shift; cmd_list "$@" ;;
  type) shift; cmd_type "$@" ;;
  send|message|msg) shift; cmd_send "$@" ;;
  read) shift; cmd_read "$@" ;;
  keys) shift; cmd_keys "$@" ;;
  name) shift; cmd_name "$@" ;;
  resolve) shift; cmd_resolve "$@" ;;
  *) die "unknown command: $1. Run 'tmux-bridge' for usage." ;;
esac
